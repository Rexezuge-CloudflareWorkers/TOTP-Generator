{
	"name": "totp-generator",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"cf-typegen": "wrangler types",
		"buildApp": "npm --prefix app run release",
		"build": "npm run buildApp",
		"checks": "npm run typecheck && npm --prefix app run lint",
		"typecheck": "tsc --noEmit && npm --prefix app run typecheck",
		"predeploy": "npm run build",
		"deploy:dry-run": "wrangler deploy --dry-run",
		"deploy": "wrangler deploy"
	},
	"dependencies": {
		"chanfana": "^3.3.x",
		"hono": "^4.12.x",
		"otplib": "^13.4.x",
		"zod": "^4.4.x"
	},
	"devDependencies": {
		"@types/node": "25.9.x",
		"typescript": "^5.9.x",
		"wrangler": "^4.99.x"
	}
}
